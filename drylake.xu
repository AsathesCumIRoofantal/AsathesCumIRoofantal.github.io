xu: 1
kind: ApplicationBuildRunbook
metadata:
  name: find-in-all-error-pages-slivertoboxadapter-child
  owner: local
  status: draft
  mode: review
intent:
  rawPrompt: >-
    Find in all error pages-:

    SliverToBoxAdapter(child: 'PageName'View(isEmbedded: true)),on_details.. the page like
    'AirsMission'View..

    >>>

    do make
     final bool isEmbedded;
    And 

    shrinkWrap: isEmbedded,
            physics: isEmbedded ? const NeverScrollableScrollPhysics() : null,
    in any Scrolable-list in "'PageName'View" and when page is error free do go to next page..
  purpose: >-
    Find in all error pages-: SliverToBoxAdapter(child: 'PageName'View(isEmbedded:
    true)),on_details..
  users:
    - developer
  goals:
    - Create an inspectable drylake.xu runbook.
    - Confirm purpose before architecture work.
    - Approve architecture before execution handoff.
    - Generate native agent files from the approved runbook.
  nonGoals:
    - Do not deploy or publish from this runbook.
    - Do not run provisioning commands automatically.
    - Do not call production APIs from the runbook flow.
  constraints:
    - Local-first workflow.
    - Preview provisioning before execution.
    - Keep generated artifacts under .drylake/generated first.
    - Preserve user files with backups before overwrite.
confirmation:
  required: true
  status: pending
  userApprovedIntent: false
  userApprovedArchitecture: false
  userApprovedProvisioning: false
architecture:
  status: proposed
  summary: >-
    Use the current workspace as the source of truth (Workspace: air_app). Keep the runbook,
    approvals, generated files, and phase handoffs inspectable on disk.
  decisions:
    - id: ADR-001
      choice: Use drylake.xu as the workflow source of truth.
      rationale: >-
        The user can inspect and version purpose, constraints, architecture, phases, and handoff
        instructions.
    - id: ADR-002
      choice: Generate preview artifacts before installing root instruction files.
      rationale: Preview-first generation makes the workflow safe to test in development.
  risks:
    - The generated draft is local and deterministic when no integrated AI is available.
    - Execution still depends on the user's chosen coding agent.
  assumptions:
    - The user will approve purpose and architecture before execution.
    - Provisioning commands are reviewed manually.
provisioning:
  status: draft
  commands:
    - npm install
    - npm run build
  filesToCreate:
    - .drylake/generated/RUNBOOK.md
    - .drylake/generated/AGENTS.md
    - .drylake/generated/CLAUDE.md
  environmentVariables: []
  externalServices: []
  safety:
    requiresApprovalBeforeExecution: true
    executeAutomatically: false
phases:
  - id: 01-intake
    title: Confirm application purpose
    agent: claude-code
    gate: user-confirmation
    status: pending
    objective: Confirm what the user wants built.
    inputs:
      - user prompt
    outputs:
      - confirmed purpose
      - goals
      - non-goals
      - constraints
    steps:
      - id: 01-intake-step-01
        text: Parse the user prompt.
        status: pending
      - id: 01-intake-step-02
        text: Identify the application purpose.
        status: pending
      - id: 01-intake-step-03
        text: Identify target users.
        status: pending
      - id: 01-intake-step-04
        text: Identify non-goals and constraints.
        status: pending
      - id: 01-intake-step-05
        text: Ask the user to confirm before architecture work starts.
        status: pending
    acceptance:
      - Purpose is confirmed.
      - Goals and non-goals are explicit.
      - Constraints are recorded.
  - id: 02-architecture
    title: Approve architecture
    gate: architecture-approval
    status: complete
    objective: Agree on technical architecture before implementation.
    inputs: []
    outputs: []
    steps:
      - id: 02-architecture-step-01
        text: Propose architecture.
        status: pending
      - id: 02-architecture-step-02
        text: List major dependencies.
        status: pending
      - id: 02-architecture-step-03
        text: List data model assumptions.
        status: pending
      - id: 02-architecture-step-04
        text: List deployment assumptions.
        status: pending
      - id: 02-architecture-step-05
        text: Ask the user to approve or revise.
        status: pending
    acceptance:
      - Architecture is approved.
      - Risks and assumptions are documented.
  - id: 03-provisioning
    title: Preview provisioning
    gate: provisioning-approval
    status: complete
    objective: Preview project setup, commands, files, and environment requirements.
    inputs: []
    outputs: []
    steps:
      - id: 03-provisioning-step-01
        text: Generate setup commands.
        status: pending
      - id: 03-provisioning-step-02
        text: Generate file creation plan.
        status: pending
      - id: 03-provisioning-step-03
        text: Generate environment variable list.
        status: pending
      - id: 03-provisioning-step-04
        text: Require approval before running or handing off commands.
        status: pending
    acceptance:
      - Provisioning plan is approved.
      - No command executes without user confirmation.
  - id: 04-implementation
    title: Implement in vertical slices
    gate: phase-review
    status: complete
    objective: Build the application step by step.
    inputs: []
    outputs: []
    steps:
      - id: 04-implementation-step-01
        text: Implement one thin vertical slice.
        status: pending
      - id: 04-implementation-step-02
        text: Avoid unrelated refactors.
        status: pending
      - id: 04-implementation-step-03
        text: Keep changes reversible.
        status: pending
      - id: 04-implementation-step-04
        text: Verify each phase before continuing.
        status: pending
    acceptance:
      - Changed files are summarized.
      - Checks pass or failures are explained.
  - id: 05-verification
    title: Verify and hand off
    gate: final-review
    status: active
    objective: Validate implementation and produce final handoff.
    inputs: []
    outputs: []
    steps:
      - id: 05-verification-step-01
        text: Run build.
        status: pending
      - id: 05-verification-step-02
        text: Run tests.
        status: pending
      - id: 05-verification-step-03
        text: Run lint.
        status: pending
      - id: 05-verification-step-04
        text: Summarize changed files.
        status: pending
      - id: 05-verification-step-05
        text: Summarize remaining risks.
        status: pending
    acceptance:
      - Verification is complete.
      - Handoff notes are generated.
checks:
  install: npm install
  dev: npm run dev
  build: npm run build
  test: npm test
  lint: npm run lint
agentTargets:
  agentsMd: true
  claudeMd: true
  copilotInstructions: true
  cursorRules: true
  codexSkill: true
  openclawSkill: true
handoff:
  defaultAgent: claude-code
  instructions:
    - Follow phases in order.
    - Do not skip approval gates.
    - Do not provision infrastructure without explicit confirmation.
    - Always summarize changed files and verification results.
